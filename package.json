{
  "name": "blog-alessio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal blog of Alessio Sopranzi — engineering, music, and the workshop in between.",
  "author": "Alessio Sopranzi",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/build-og.ts && next build",
    "build:next": "next build",
    "build:og": "tsx scripts/build-og.ts",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm lint && pnpm build"
  },
  "dependencies": {
    "feed": "^4.2.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.460.0",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-to-string": "^4.0.0",
    "next": "^16.2.0",
    "next-intl": "^4.0.0",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-smartypants": "^3.0.2",
    "shiki": "^1.24.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "satori": "^0.12.0",
    "sharp": "^0.34.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
