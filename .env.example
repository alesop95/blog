# Copy to `.env.local` for local dev. GitHub Actions sets these at deploy time.

# Public URL of the site. In local dev: http://localhost:3000
# In production: https://<github-username>.github.io  (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional base path. Leave empty for user-site mode (repo named <user>.github.io).
# Set to "/<repo-name>" if you fall back to project-site mode.
BASE_PATH=""
